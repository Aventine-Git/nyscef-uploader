# AWS credentials — create a dedicated IAM user (see SERVER-DEPLOY.md)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# SQS queue URL — find this in the AWS Console under SQS > Queues
NYSCEF_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/YOUR_QUEUE_NAME

# NYSCEF login credentials
NYSCEF_USERNAME=
NYSCEF_PASSWORD=

# Cloudflare cookie injection
# Set to true — the server has a fixed IP, so this works and prevents Cloudflare challenges.
CF_INJECT_COOKIE=true

# Notification recipients (comma-separated)
# Who gets emailed when an upload succeeds or fails (if the negotiator has no email)
NOTIFY_RECIPIENTS=catherine@aventine.ai

# Slack user IDs to notify on errors (comma-separated, optional)
# Use Slack user IDs (e.g. U012AB3CD), not display names
NOTIFY_SLACK_RECIPIENTS=

# Warm up the browser on container startup (optional)
# true = browser starts immediately so the first upload has no cold-start delay
WARM_START_LOGIN=false
